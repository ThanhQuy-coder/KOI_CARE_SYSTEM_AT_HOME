@page
@model KoiCareSystemAtHome.WebApplication.Pages.LoginPage.forgotPasswordModel
@{
    Layout = "_LoginLayout";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12 col-md-9">

            <div class="mb-4 mt-5">
                <a href="javascript:history.back()" class="text-white text-decoration-none hover-back">
                    <i class="fas fa-arrow-left fa-sm"></i> Go Back
                </a>
            </div>

            <div class="card o-hidden border-0 shadow-lg mb-5" style="border-radius: 15px;">
                <div class="card-body p-0" style="background-image: url('/images/7792008.jpg'); background-size: cover; background-position: center;">
                    <div class="row">
                        <div class="col-lg-6 d-none d-lg-block bg-password-image" style="background-color: rgba(255, 255, 255, 0.1);">
                        </div>

                        <div class="col-lg-6" style="background-color: rgba(0, 0, 0, 0.75); backdrop-filter: blur(10px); min-height: 500px;">
                            <div class="p-5">
                                <div class="text-center">
                                    <div class="mb-3">
                                        <i class="fas fa-key fa-3x text-info"></i>
                                    </div>
                                    <h1 class="h3 text-white font-weight-bold mb-2">Forgot Your Password?</h1>
                                    <p class="mb-4 text-white-50">
                                        We get it, stuff happens. Just enter your email address below
                                        and we'll send you a link to reset your password!
                                    </p>
                                </div>

                                <form class="user" method="post">
                                    <div class="form-group">
                                        <input type="email" class="form-control form-control-user shadow-sm"
                                               id="exampleInputEmail" aria-describedby="emailHelp"
                                               placeholder="Enter Email Address..." required>
                                    </div>

                                    <button type="submit" class="btn btn-primary btn-user btn-block font-weight-bold shadow-sm">
                                        Reset Password
                                    </button>
                                </form>

                                <hr class="border-light opacity-20">

                                <div class="text-center">
                                    <a class="small text-info font-weight-bold" asp-page="/LoginPage/Register">Create an Account!</a>
                                </div>
                                <div class="text-center mt-2">
                                    <a class="small text-white-50 text-decoration-none" asp-page="/LoginPage/Index">
                                        Remembered? <span class="text-info font-weight-bold">Login!</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    /* Bo góc và khoảng cách cho Input */
    .form-control-user {
        border-radius: 10px !important;
        padding: 1.5rem 1rem !important;
        background: rgba(255, 255, 255, 0.9);
        border: none;
    }

        .form-control-user:focus {
            background: #fff;
            box-shadow: 0 0 0 0.2rem rgba(54, 185, 204, 0.25) !important;
        }

    /* Nút bấm mượt mà */
    .btn-user {
        border-radius: 10px !important;
        padding: 0.75rem !important;
        transition: all 0.3s ease;
    }

        .btn-user:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.4) !important;
        }

    /* Hiệu ứng cho nút Back */
    .hover-back {
        opacity: 0.8;
        transition: 0.2s;
    }

        .hover-back:hover {
            opacity: 1;
            text-shadow: 0 0 8px rgba(255,255,255,0.5);
        }

    hr {
        border-top: 1px solid rgba(255,255,255,0.1);
    }
</style>